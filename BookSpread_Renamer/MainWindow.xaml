<Window x:Class="BookSpread_Renamer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BookSpread Renamer" Height="740" Width="960"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- 하단: 진행률 -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
            <ProgressBar x:Name="ProgressBar" Height="16" Minimum="0" Maximum="100" Value="0"/>
            <TextBlock x:Name="StatusText" Margin="0,3,0,0" FontSize="11"
                       Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 상단: 검색 경로 -->
        <GroupBox DockPanel.Dock="Top" Header="검색 경로" Margin="0,0,0,6">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 현재 검색 경로 목록 -->
                <ListBox x:Name="PathListBox" Grid.Row="0" Grid.Column="0"
                         Height="80" SelectionMode="Single"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Top">
                    <Button Content="폴더 추가" Width="90" Margin="0,0,0,4" Click="AddPath_Click"/>
                    <Button Content="제거" Width="90" Click="RemovePath_Click"/>
                </StackPanel>

                <!-- 최근 사용 경로 -->
                <DockPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                    <TextBlock DockPanel.Dock="Left" Text="최근 경로:" VerticalAlignment="Center"
                               Margin="0,0,8,0" FontSize="11"/>
                    <Button DockPanel.Dock="Right" Content="추가" Width="55" Margin="6,0,0,0"
                            Click="AddRecentPath_Click"/>
                    <ComboBox x:Name="RecentPathCombo" FontSize="11"/>
                </DockPanel>
            </Grid>
        </GroupBox>

        <!-- 작업 버튼 (2행 3열) -->
        <GroupBox DockPanel.Dock="Top" Header="작업" Margin="0,0,0,6">
            <UniformGrid x:Name="ActionPanel" Rows="2" Columns="3" Margin="4">
                <Button Style="{StaticResource ActionBtn}" Content="Spread File&#10;(파일 분류 이동)" Click="SpreadFile_Click"/>
                <Button Style="{StaticResource ActionBtn}" Content="Clean File Names&#10;(파일 이름 정리)" Click="CleanNames_Click"/>
                <Button Style="{StaticResource ActionBtn}" Content="Get File List&#10;(목록 저장)" Click="GetFileList_Click"/>
                <Button Style="{StaticResource ActionBtn}" Content="Remove Duplicates&#10;(중복 제거)" Click="RemoveDuplicates_Click"/>
                <Button Style="{StaticResource ActionBtn}" Content="Clean Broken Filenames&#10;(깨진 파일명 정리)" Click="CleanBroken_Click"/>
                <Button Style="{StaticResource ActionBtn}" Content="Reclassify ResultPDF&#10;(재분류)" Click="Reclassify_Click"/>
            </UniformGrid>
        </GroupBox>

        <!-- 로그 -->
        <GroupBox Header="로그">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="LogBox" Grid.Row="0"
                         IsReadOnly="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11"/>
                <Button Grid.Row="1" Content="로그 지우기" HorizontalAlignment="Right"
                        Margin="0,4,0,0" Padding="8,2" Click="ClearLog_Click"/>
            </Grid>
        </GroupBox>

    </DockPanel>
</Window>
